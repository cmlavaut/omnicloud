pipeline {
    agent any
    tools {
        nodejs "nodejs"
    }
    environment {
        HOST = "10.10.10.83"
        BACKEND_URL = ""
    }

    stages {
        stage ("Clone Repository") { 
            steps {
                git branch: "master", url: "https://github.com/cmlavaut/omnicloud.git", credentialsId: "github-kmi"
            }
        }

        stage ("Install Dependencies") {
            steps {
                dir ("omnicloud/app-frontend") {
                    sh 'npm install'
                }
            }
        }

        stage ("Deploy to EC2") {
            steps {
                sshagent (["ec2-ssh-pem"]) {
                    sh """
                    scp -o StrictHostKeyChecking=no -r omnicloud/app-frontend ec2-user@${HOST}:/home/ec2-user/
                    ssh ec2-user@${HOST} '
                        cd /home/ec2-user/app-frontend &&
                        export BACKEND_URL=${BACKEND_URL}
                        npm install --production &&
                        pm2 delete app-frontend || true &&
                        pm2 start server.js --name app-frontend &&
                        pm2 save
                    '                 
                    """
                }
            }
        }
    }
    
}

